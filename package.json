{
  "name": "@0xsarwagya/clinical-receipt",
  "version": "0.2.0",
  "description": "Portable, independently verifiable receipts of how a clinical AI output came to exist.",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xsarwagya/clinical-receipt.git"
  },
  "homepage": "https://oss.sarwagya.wtf/clinical-receipt",
  "keywords": [
    "clinical-ai",
    "provenance",
    "audit",
    "merkle",
    "selective-disclosure",
    "verification",
    "healthcare",
    "fhir",
    "typescript"
  ],
  "sideEffects": [
    "./dist/fhir.js",
    "./dist/fhir/register.js",
    "./dist/fhir/canonicalize.js"
  ],
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./verify": {
      "types": "./dist/verify.d.ts",
      "import": "./dist/verify.js"
    },
    "./fhir": {
      "types": "./dist/fhir.d.ts",
      "import": "./dist/fhir.js"
    }
  },
  "bin": {
    "clinical-receipt": "./dist/cli.js"
  },
  "files": [
    "dist",
    "spec",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "prepare": "tsup && tsc -p tsconfig.build.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsup": "^8.3.5",
    "tsx": "^4.23.0",
    "typescript": "5.9.2",
    "vitest": "^3.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
